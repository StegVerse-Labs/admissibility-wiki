        },
        "input_state": {
          "source": "GitHub notification, repository state, current handoff, checks, files, manifests, and receipts",
          "required": true
        },
        "proposed_action": {
          "source": "current handoff active task or explicitly permitted repair class",
          "required": true
        },
        "actor": {
          "value": "scheduled bootstrap handoff executor",
          "authority_posture": "non-sovereign tool participant"
        },
        "target": {
          "source": "repository resolved from event and confirmed against current handoff",
          "required": true
        },
        "scope": {
          "default": "repository",
          "cross_repository_requires_explicit_authority": true
        },
        "policy_reference": {
          "sources": [
            "automation prompt boundaries",
            "repository handoff constraints",
            "repository workflow and release policy",
            "applicable ecosystem governance rules"
          ],
          "required": true
        },
        "delegation_reference": {
          "source": "explicit task or repair permission in current handoff",
