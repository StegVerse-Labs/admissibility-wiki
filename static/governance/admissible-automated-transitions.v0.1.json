          "release_deploy_merge_or_ecosystem_authority_inferred": false
        },
        "review_posture": {
          "bounded_declared_work": "automated_review",
          "ambiguous_destructive_irreversible_credentialed_or_cross_boundary": "human_review_required"
        },
        "execution_context": {
