{
  "manifest_id": "admissible-automated-transitions.v0.1",
  "manifest_version": "0.1.0",
  "generated_at": "2026-07-10T00:00:00Z",
  "scope": "StegVerse bootstrap orchestration observability",
  "authority_boundary": "The manifest catalogs declared automation and does not grant execution authority.",
  "transitions": [
    {
      "transition_id": "automation.github-handoff-watch.hourly.v1",
      "name": "GitHub Handoff Watch",
      "lifecycle_state": "ACTIVE_BOOTSTRAP_ORCHESTRATION",
      "trigger": {
        "provider": "Gmail",
        "mode": "condition_watch",
        "schedule": "hourly",
        "event_classes": [
          "github_failure",
          "github_completion_or_progress"
        ]
      },
      "scope": {
        "default_level": "repository",
        "cross_repository_action_requires_explicit_handoff_authority": true,
        "ecosystem_authority_inferred": false
      },
      "task_authority": {
        "source": "current *_MIRROR_HANDOFF.md",
        "event_does_not_select_task": true
      },
      "permitted_actions": [
        "inspect_notification",
        "resolve_repository_context",
        "read_current_handoff",
        "inspect_related_github_context",
        "classify_failure_or_completion",
        "apply_bounded_explicitly_authorized_repair",
        "verify_declared_completion_conditions",
        "update_handoff",
        "begin_next_declared_bounded_task"
      ],
      "prohibited_actions_without_explicit_authority": [
        "archive",
        "delete",
        "deploy",
        "release",
        "tag",
        "merge",
        "send_email",
        "modify_external_repository"
      ],
      "stop_conditions": [
        "ambiguous_authority",
        "destructive_action_required",
        "cross_boundary_action_required",
        "tests_unverifiable",
        "required_credentials_unavailable",
        "no_next_task_declared"
      ],
      "event_rejection_conditions": [
        "stale",
        "duplicate",
        "unrelated",
        "partial_progress_without_completion_evidence"
      ],
      "verification_requirements": [
        "declared_files_or_outputs_present",
        "declared_tests_or_checks_verified_when_available",
        "authority_boundary_preserved",
        "handoff_advanced_only_after_verified_completion"
      ],
      "receipt_refs": [
        "receipts/admissible-automated-transitions-observatory-receipt.json"
      ],
      "public_page": "docs/governance/admissible-automated-transitions.md"
    }
  ]
}
