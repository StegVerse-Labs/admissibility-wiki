{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stegverse-labs.github.io/admissibility-wiki/schemas/decision-commitment-record-candidate.schema.json",
  "title": "Decision Commitment Record Candidate",
  "type": "object",
  "required": ["record_id", "decision_maker", "authority_basis", "commitment_timestamp", "committed_action", "decision_criteria", "evidence_refs", "known_unknowns", "alternatives_considered", "threshold_trigger", "stop_mechanism", "recoverability_profile", "authority_boundary"],
  "properties": {
    "record_id": {"type": "string", "minLength": 1},
    "decision_maker": {"type": "string", "minLength": 1},
    "authority_basis": {"type": "string", "minLength": 1},
    "commitment_timestamp": {"type": "string", "format": "date-time"},
    "committed_action": {"type": "string", "minLength": 1},
    "decision_criteria": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "known_unknowns": {"type": "array", "items": {"type": "string"}},
    "alternatives_considered": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "threshold_trigger": {"type": "string", "minLength": 1},
    "stop_mechanism": {"type": "string", "minLength": 1},
    "intervention_deadline": {"type": "string", "format": "date-time"},
    "recoverability_profile": {
      "type": "object",
      "required": ["rollback_test_receipt", "irreversibility_boundary", "recovery_owner", "validity_window"],
      "properties": {
        "rollback_test_receipt": {"type": "string", "minLength": 1},
        "irreversibility_boundary": {"type": "string", "minLength": 1},
        "recovery_owner": {"type": "string", "minLength": 1},
        "validity_window": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "authority_boundary": {
      "type": "object",
      "required": ["record_is_execution_authority", "human_commitment_is_admissibility"],
      "properties": {
        "record_is_execution_authority": {"const": false},
        "human_commitment_is_admissibility": {"const": false}
      }
    }
  },
  "additionalProperties": true
}
