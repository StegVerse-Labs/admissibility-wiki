{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stegverse.org/schemas/external-chat-publication-transition.schema.json",
  "title": "External Chat Wiki Publication Transition",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "transition_type", "package_id", "correction_receipt_id", "publisher_ref", "target_path", "decision", "source_commit_ref", "evidence_references", "publication_executed", "boundary"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "transition_type": {"const": "external_framework_wiki_publication_transition"},
    "package_id": {"type": "string", "minLength": 1},
    "correction_receipt_id": {"type": "string", "minLength": 1},
    "publisher_ref": {"type": "string", "minLength": 1},
    "target_path": {"type": "string", "pattern": "^docs/external-frameworks/(reports/)?[a-z0-9][a-z0-9._/-]*$"},
    "decision": {"enum": ["ALLOW_PUBLICATION_CANDIDATE", "DENY_PUBLICATION", "REVIEW_REQUIRED"]},
    "source_commit_ref": {"type": "string", "minLength": 1},
    "evidence_references": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "publication_executed": {"const": false},
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transition_is_not_repository_write", "transition_is_not_certification", "transition_creates_no_standing", "separate_repository_mutation_required"],
      "properties": {
        "transition_is_not_repository_write": {"const": true},
        "transition_is_not_certification": {"const": true},
        "transition_creates_no_standing": {"const": true},
        "separate_repository_mutation_required": {"const": true}
      }
    }
  }
}
