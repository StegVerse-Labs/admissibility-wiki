{
  "artifact_type": "external_framework_expansion_policy",
  "schema_version": "0.1",
  "repo": "StegVerse-Labs/admissibility-wiki",
  "goal_id": "external-framework-expansion-cycle",
  "standard_path": "docs/external-frameworks/evaluation-standard.md",
  "template_path": "docs/external-frameworks/external-framework-template.md",
  "failure_class_catalog_path": "docs/external-frameworks/failure-class-catalog.md",
  "allowed_source_states": [
    "SOURCE_RECORDED_CROSSWALK_PROVISIONAL",
    "SOURCE_BLOCKED_FAIL_CLOSED",
    "ARTIFACT_PACKAGE_REQUIRED_FAIL_CLOSED",
    "FIRST_FRAMEWORK_CYCLE_COMPLETE"
  ],
  "required_new_entry_fields": [
    "framework_id",
    "name",
    "status",
    "path",
    "manifest_path",
    "source",
    "testbench_state",
    "claims_certification",
    "claims_endorsement",
    "claims_execution_authority"
  ],
  "required_manifest_fields": [
    "artifact_type",
    "schema_version",
    "framework_id",
    "name",
    "source_reference",
    "source_version",
    "allowed_use_boundary",
    "claims",
    "non_claims",
    "transition_table_mapping",
    "SPE_overlap",
    "StegVerse_ecosystem_overlap",
    "fail_closed_conditions",
    "boundary"
  ],
  "required_page_sections": [
    "Evidence Provenance",
    "Framework-Term Definitions",
    "Reconciliation Class",
    "Admissibility Relationship",
    "Execution Authority Boundary",
    "Evaluation Result Posting",
    "Non-Claims",
    "Challenge Path"
  ],
  "evidence_classification_codes": [
    "F1",
    "F2",
    "O1",
    "O2",
    "R1",
    "S1",
    "S2",
    "I1",
    "V1",
    "H1"
  ],
  "required_evidence_provenance_classes": [
    "official_framework_sources",
    "official_implementation_sources",
    "observed_behavior",
    "reproduced_behavior",
    "stegverse_analysis",
    "interoperability_assessment",
    "standing"
  ],
  "required_runtime_result_artifacts": [
    "input_prompt_or_planner_output",
    "selected_demo_repository_version_release_or_commit",
    "runtime_configuration",
    "policy_or_rule_set",
    "expected_boundary",
    "observed_output",
    "returned_audit_evidence_or_trace",
    "screenshot_or_raw_payload",
    "timestamp",
    "source_url_or_commit_hash"
  ],
  "required_boundaries": {
    "claims_certification": false,
    "claims_endorsement": false,
    "claims_execution_authority": false,
    "certification_claim": false,
    "endorsement_claim": false,
    "execution_authority_claim": false,
    "commit_time_authority_claim": false,
    "compatibility_manifest_is_authority": false
  },
  "fail_closed_conditions": [
    "missing source state",
    "missing manifest path",
    "missing framework page",
    "missing native terminology table",
    "missing evidence provenance section",
    "missing transition-table mapping",
    "missing SPE overlap",
    "missing StegVerse ecosystem overlap",
    "any certification, endorsement, execution authority, or commit-time authority claim appears",
    "public runtime-result claim without required runtime result artifacts"
  ],
  "boundary": {
    "expansion_policy_is_authority": false,
    "expansion_policy_is_certification": false,
    "new_entries_require_source_state": true,
    "new_entries_require_native_terminology": true,
    "new_entries_require_evidence_provenance": true,
    "new_entries_require_transition_table_mapping": true,
    "new_entries_preserve_non_authority_boundary": true,
    "observed_behavior_must_not_be_generalized_beyond_captured_evidence": true,
    "compatibility_is_not_certification": true,
    "standing_is_never_inherited_from_publication": true
  }
}
