    "name",
    "status",
    "path",
    "manifest_path",
    "source",
    "testbench_state",
    "claims_certification",
    "claims_endorsement",
    "claims_execution_authority"
  ],
  "required_manifest_fields": [
    "artifact_type",
    "schema_version",
    "framework_id",
    "name",
    "source_reference",
    "source_version",
    "allowed_use_boundary",
    "claims",
    "non_claims",
    "transition_table_mapping",
    "SPE_overlap",
    "StegVerse_ecosystem_overlap",
    "fail_closed_conditions",
    "boundary"
